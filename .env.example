# NutriMenu - Environment Variables Template
# Copy this file to .env and fill in the appropriate values

# Flask Configuration
FLASK_ENV=
FLASK_HOST=
FLASK_PORT=
DEBUG=

# Flask Security
# IMPORTANT: Change this to a strong random string in production
SECRET_KEY=

# Database Configuration (for Phase 2+)
# DATABASE_URL=sqlite:///nutrimenu.db

# API Keys (for Phase 4+ when integrations are added)
# NUTRITION_API_KEY=your-api-key-here
# 3D_MODEL_API_KEY=your-api-key-here
# THIRD_PARTY_API_KEY=your-api-key-here

# Email Configuration (for Phase 2+ authentication)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@example.com
# MAIL_PASSWORD=your-password

# Other Configuration
# LOG_LEVEL=INFO
# WORKERS=4
